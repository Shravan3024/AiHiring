# Environment Variables Template
# Copy this file to `backend/.env` and fill in your values

# ==================== GOOGLE AI CONFIGURATION ====================
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Available models: gemini-2.0-flash (recommended), gemini-1.5-flash, gemini-1.5-pro
GENAI_MODEL=gemini-2.0-flash

# ==================== AI SERVICE CONFIGURATION ====================
# Flask server host and port
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=5000

# Environment: development, production, testing
FLASK_ENV=development

# AI Response temperature (0-1, lower = deterministic, higher = creative)
AI_TEMPERATURE=0.7

# Maximum tokens in response
MAX_TOKENS=2048

# API timeout in seconds
API_TIMEOUT=30

# ==================== DATABASE CONFIGURATION ====================
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=msk_db
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Full database URL (optional, overrides above)
# DATABASE_URL=postgresql://user:password@localhost:5432/msk_db

# ==================== FILE UPLOAD CONFIGURATION ====================
# Directory for uploads (relative to backend/)
UPLOAD_FOLDER=uploads

# Maximum file size in bytes (50MB = 52428800)
MAX_FILE_SIZE=52428800

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,docx,doc,txt

# ==================== CACHE CONFIGURATION ====================
# Enable/disable response caching
CACHE_ENABLED=true

# Cache time-to-live in seconds (3600 = 1 hour)
CACHE_TTL=3600

# ==================== LOGGING CONFIGURATION ====================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (relative to ai_service/)
LOG_FILE=ai_service.log

# ==================== NLP MODELS ====================
# spaCy model for NER and tokenization
SPACY_MODEL=en_core_web_sm

# Transformer model for embeddings (optional)
TRANSFORMER_MODEL=distilbert-base-uncased

# ==================== NODE.JS BACKEND ====================
# Port for Node.js server
PORT=3000

# Environment
NODE_ENV=development

# Database for Node.js
DATABASE_URL=postgresql://postgres:password@localhost:5432/msk_db

# JWT Secret for authentication
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# ==================== OPTIONAL: PRODUCTION ====================
# AWS Configuration (if using AWS S3 for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=us-east-1

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ==================== OPTIONAL: MONITORING ====================
# Sentry for error tracking
SENTRY_DSN=your_sentry_dsn_url

# Redis for caching (if using Redis instead of in-memory)
REDIS_URL=redis://localhost:6379/0

# ==================== OPTIONAL: DEVELOPMENT ====================
# Debug mode (development only)
DEBUG=true

# Verbose logging
DEBUG_LOGGING=false

# Allow all CORS origins (development only)
CORS_ORIGIN=*
